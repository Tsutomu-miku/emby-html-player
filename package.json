{
  "name": "emby-html-player",
  "version": "0.2.7",
  "description": "Electron desktop client for browsing and playing Emby media libraries.",
  "type": "module",
  "homepage": "https://github.com/Tsutomu-miku/emby-html-player",
  "main": "out/main/index.mjs",
  "scripts": {
    "dev": "pnpm build:native:view && electron-vite dev --watch",
    "dev:web": "vite",
    "build": "electron-vite build",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "pnpm build:web && gh-pages -d dist -b gh-pages --dotfiles --nojekyll",
    "bundle:native:mac": "node scripts/bundle-macos-mpv.mjs",
    "build:native:player": "node scripts/build-mpv-player-addon.mjs",
    "build:native:view": "pnpm build:native:player",
    "stage:native": "node scripts/stage-native-mpv.mjs",
    "verify:native": "node scripts/verify-native-resources.mjs",
    "package": "pnpm build:native:view && pnpm verify:native && pnpm build && electron-builder --publish never",
    "package:mac": "pnpm build:native:view && pnpm verify:native && pnpm build && electron-builder --mac --publish never",
    "package:linux": "pnpm build:native:view && pnpm verify:native && pnpm build && electron-builder --linux --publish never",
    "package:win": "pnpm build:native:view && pnpm verify:native && pnpm build && electron-builder --win --publish never",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "node-gyp": "^12.4.0",
    "postcss": "^8.5.15",
    "sass": "^1.83.4",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "hls.js": "^1.6.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.tsutomu-miku.emby-html-player",
    "productName": "Emby Desktop Player",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/native",
        "to": "native",
        "filter": [
          "**/*",
          "!**/include/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "category": "AudioVideo",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
